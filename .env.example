# Keep SQLite by leaving DATABASE_URL unset.
DB_DRIVER=sqlite
DB_PATH=data/usage.sqlite

# PostgreSQL / Supabase example:
# DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# MySQL example:
# DATABASE_URL=mysql://user:password@127.0.0.1:3306/ai_token_dashboard

# Optional pool tuning.
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT_MS=10000

# Display timezone (IANA name) for the heatmap's hour-of-day and the price-lock
# "today" boundary. Leave unset to follow the server's local timezone; set it
# explicitly when deploying on a UTC host, e.g. DISPLAY_TZ=Asia/Shanghai.
# DISPLAY_TZ=Asia/Shanghai
